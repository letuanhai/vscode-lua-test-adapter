{
  "name": "luaunit-test-adapter",
  "displayName": "LuaUnit Test-Adapter",
  "description": "Run your LuaUnit tests in the Sidebar of Visual Studio Code - a personal fork of lej.vscode-lua-test-adapter",
  "author": "Le Tuan Hai <letuanhai@users.noreply.github.com>",
  "publisher": "lth",
  "version": "1.0.7",
  "license": "MIT",
  "repository": {
    "type": "github",
    "url": "https://github.com/letuanhai/vscode-luaunit-test-adapter"
  },
  "categories": [
    "Testing"
  ],
  "keywords": [
    "test",
    "testing",
    "lua",
    "adapter"
  ],
  "main": "out/main.js",
  "scripts": {
    "clean": "rimraf out *.vsix",
    "prebuild": "tsx scripts/generate-config.ts",
    "build": "tsc",
    "prewatch": "npm run prebuild",
    "watch": "tsc -w",
    "rebuild": "npm run clean && npm run build",
    "package": "vsce package",
    "prepublish": "npm run rebuild",
    "publish": "vsce publish",
    "login": "vsce login lth"
  },
  "dependencies": {
    "tslib": "~2.8.1",
    "vscode-test-adapter-api": "~1.9.0",
    "vscode-test-adapter-util": "~0.7.1"
  },
  "devDependencies": {
    "@types/node": "~25.9.1",
    "@types/vscode": "~1.120.0",
    "@vscode/vsce": "~3.9.1",
    "rimraf": "~6.1.3",
    "tsx": "^4.22.4",
    "typescript": "~6.0.3"
  },
  "engines": {
    "vscode": "^1.120.0"
  },
  "extensionDependencies": [
    "hbenl.vscode-test-explorer"
  ],
  "activationEvents": [
    "onLanguage:lua",
    "onView:test-explorer",
    "onCommand:test-explorer.reload",
    "onCommand:test-explorer.run-all",
    "onCommand:test-explorer.run-file",
    "onCommand:test-explorer.run-test-at-cursor",
    "onCommand:test-explorer.rerun",
    "onCommand:test-explorer.debug-test-at-cursor",
    "onCommand:test-explorer.redebug",
    "onCommand:test-explorer.cancel",
    "onStartupFinished"
  ],
  "contributes": {
    "configuration": {
      "type": "object",
      "properties": {
        "luaunit-test-adapter.luaExe": {
          "description": "Path to Lua executable.",
          "type": "string",
          "default": "lua",
          "scope": "resource"
        },
        "luaunit-test-adapter.testGlob": {
          "description": "Glob used to find test files.",
          "type": "string",
          "default": "**/[tT]est*.{lua}",
          "scope": "resource"
        },
        "luaunit-test-adapter.testRegex": {
          "description": "Regex matched against function and method names to identify tests.",
          "type": "string",
          "default": "^[tT]est[a-zA-Z0-9_]*$",
          "scope": "resource"
        },
        "luaunit-test-adapter.suiteRegex": {
          "description": "Regex matched against class names in 'function ClassName:method()' syntax to identify test suites.",
          "type": "string",
          "default": "^Test[a-zA-Z0-9_]*$",
          "scope": "resource"
        },
        "luaunit-test-adapter.testEncoding": {
          "description": "Test file encoding.",
          "type": "string",
          "default": "utf8",
          "scope": "resource"
        },
        "luaunit-test-adapter.decorationRegex": {
          "description": "Regex matched against test output to extract the line number ('line' group) and failure message ('message' group).",
          "type": "string",
          "default": "\\.lua:(?<line>[1-9][0-9]*):(?<message>.*)stack traceback:",
          "scope": "resource"
        },
        "luaunit-test-adapter.debugExtension": {
          "description": "Select Lua debugging extension used to debug tests.",
          "type": "string",
          "enum": [
            "actboy168.lua-debug",
            "tomblind.local-lua-debugger-vscode",
            "ismoh-games.second-local-lua-debugger-vscode"
          ],
          "enumDescriptions": [
            "Lua Debug",
            "Local Lua Debugger",
            "Second Local Lua Debugger"
          ],
          "default": "actboy168.lua-debug",
          "scope": "resource"
        },
        "luaunit-test-adapter.logpanel": {
          "description": "Write diagnostic logs to an output panel",
          "type": "boolean",
          "scope": "resource"
        },
        "luaunit-test-adapter.logfile": {
          "description": "Write diagnostic logs to the given file",
          "type": "string",
          "scope": "resource"
        }
      }
    }
  }
}
